# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=alaire

# NextAuth - Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Cloudinary - Get from https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay - Get from https://dashboard.razorpay.com
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Resend - Get from https://resend.com
RESEND_API_KEY=

# Blue Dart - APIGEE credentials from https://developer.dhl.com/
# Create an App, get API Key (ClientID) and API Secret (clientSecret)
BLUEDART_CLIENT_ID=
BLUEDART_CLIENT_SECRET=

# Blue Dart - Profile credentials from Blue Dart API Gateway portal
BLUEDART_LOGIN_ID=
BLUEDART_LICENSE_KEY=
BLUEDART_API_TYPE=S
BLUEDART_VERSION=1.3
BLUEDART_CUSTOMER_NAME=
BLUEDART_CUSTOMER_CODE=
BLUEDART_BRANCH=
BLUEDART_ORIGIN_AREA=

# Instagram - Get from https://developers.facebook.com
# Create an app with Instagram Basic Display product
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
